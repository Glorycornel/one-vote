{
  "name": "one-vote",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:realtime": "pnpm --filter realtime dev",
    "dev": "pnpm -r --parallel dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "start:realtime": "pnpm --filter realtime start",
    "lint": "pnpm -r lint",
    "lint:web": "pnpm --filter web lint",
    "lint:realtime": "pnpm --filter realtime lint",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "pnpm --dir web exec prisma generate"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json,yml,yaml,css}": [
      "prettier --write"
    ],
    "web/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter web exec eslint --max-warnings=0"
    ],
    "realtime/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter realtime exec eslint --max-warnings=0"
    ]
  },
  "prisma": {
    "schema": "web/prisma/schema.prisma"
  }
}
